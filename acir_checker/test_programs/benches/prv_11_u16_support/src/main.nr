fn main(x: u16) {
    test_u16(x);
    // Safety: testing context
    unsafe {
        test_u16_unconstrained(x);
    }
}

unconstrained fn test_u16_unconstrained(x: u16) {
    test_u16(x)
}

fn test_u16(x: u16) {
    let t1: u16 = 1234;
    let t2: u16 = 4321;
    let t = t1 + t2;

    let t4 = t - t2;
    unsafe { verify_assert(t4 == t1); }

    let mut small_int = x as u16;
    let shift = small_int << (x as u8);
    unsafe { verify_assert(shift == 8); }
    assert(shift >> (x as u8) == small_int);
    unsafe { verify_assert(shift >> 15 == 0); }
    unsafe { verify_assert(shift << 15 == 0); }
}
unconstrained fn verify_assert(b: bool) { assert(b); }
