//! Bug: https://github.com/noir-lang/noir/issues/7412
//!      https://github.com/noir-lang/noir/issues/9022
//! Fix: https://github.com/noir-lang/noir/pull/7509
//! Latest related fix: https://github.com/noir-lang/noir/pull/9373
//!
//! NAVe can demonstrate inconsistencies in how right-shift
//! operations are modeled when the shift amount exceeds bit-width of 
//! the operand.
//!
//! We apply a right shift operation to the value 1 and then manually
//! constraint `x` to 8. When this bug was first reported, the semantics for
//! right shift operation lhs >> rhs were such that if rhs was at least
//! the bit-width of lhs, the output of the shift operation would be
//! zero, that is, the output is zero if rhs is not in the range
//! [0, bitwidth(lhs) - 1]. NAVe exposes the inconsistency of the constraints
//! generated by this operation by returning 'Verified', despite the reachability
//! check `verify_assert(false)` being unsatisfiable.
//!
//! With the program with `assert(x == 7)` instead, NAVe returns
//! 'Falsified' for `verify_assert(false)`, attesting the existence of a
//! valid input, and 'Verified' if we use `verify_assert(value == 0)`
//! instead.

fn main(x: u8) -> pub u8 {
    let value = 1 >> x;
    assert(x == 8);
    // assert(x == 7);
    unsafe {
        verify_assert(false);
    }
    value
}

unconstrained fn verify_assert(b: bool) { assert(b); }